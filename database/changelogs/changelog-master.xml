<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        MASTER CHANGELOG — Single Source of Truth
        ═══════════════════════════════════════════════════════════════════════

        RULES:
          1. Never remove or reorder committed <include> entries.
          2. Always append new changelogs BELOW existing ones.
          3. Run `npm run db:baseline` once (first time) to generate v1_baseline.xml.
          4. Run `npm run db:snapshot` to capture new schema changes as versioned files.

        NAMING CONVENTIONS:
          v{N}_description.xml           — structural schema migrations
          changelog_{YYYYMMDD_HHMM}.xml  — snapshots generated by db:snapshot

        CONTEXT RULES:
          metadata/ scripts  → runs on ALL environments
          seed/ scripts      → ONLY runs when context is "dev" or "local"
    -->


    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 1 — Structural Schema Migrations                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- STEP: After running `npm run db:baseline`, uncomment the line below
         and commit it together with the generated v1_baseline.xml file.    -->
    <!-- <include file="changelogs/v1_baseline.xml" relativeToChangelogFile="false"/> -->

    <!-- Add new versioned changelogs below, in chronological order:        -->
    <include file="changelogs/v1_baseline.xml" relativeToChangelogFile="false"/>
    <include file="changelogs/changelog_20260427_1000.xml" relativeToChangelogFile="false"/>
    <include file="changelogs/changelog_20260427_1023.xml" relativeToChangelogFile="false"/>
    <include file="changelogs/changelog_20260427_1119.xml" relativeToChangelogFile="false"/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 2 — Metadata: Catalogs, Views, Functions                   -->
    <!-- Runs on ALL environments. Use runOnChange:true for views/functions. -->
    <!-- Files are processed in alphabetical order — prefix with 001_, 002_ -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <includeAll path="scripts/metadata/"
                relativeToChangelogFile="false"
                errorIfMissingOrEmpty="false"/>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 3 — Seed Data (Dev / Local ONLY)                           -->
    <!-- NEVER runs in staging, CLIENTE, or PROD environments.              -->
    <!-- db-manager.sh passes - -context-filter=prod for those environments, -->
    <!-- which causes Liquibase to skip these changesets entirely.          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <includeAll path="scripts/seed/"
                relativeToChangelogFile="false"
                errorIfMissingOrEmpty="false"
                context="dev,local"/>

</databaseChangeLog>
