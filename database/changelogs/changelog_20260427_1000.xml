    <changeSet author="liquibase (generated)" id="1777294878382-51">
        <createView fullDefinition="false" replaceIfExists="true" viewName="view_invoice_status">SELECT id,
    type,
    is_sales,
    total,
    status AS doc_status,
    (COALESCE(( SELECT sum(payment_allocations.amount) AS sum
           FROM payment_allocations
          WHERE (payment_allocations.invoice_id = i.id)), (0)::numeric) + COALESCE(( SELECT sum(payments.amount) AS sum
           FROM payments
          WHERE (payments.invoice_id = i.id)), (0)::numeric)) AS paid_amount,
    COALESCE(( SELECT sum(invoice_allocations.amount) AS sum
           FROM invoice_allocations
          WHERE (invoice_allocations.target_id = i.id)), (0)::numeric) AS credited_amount,
    ((total - (COALESCE(( SELECT sum(payment_allocations.amount) AS sum
           FROM payment_allocations
          WHERE (payment_allocations.invoice_id = i.id)), (0)::numeric) + COALESCE(( SELECT sum(payments.amount) AS sum
           FROM payments
          WHERE (payments.invoice_id = i.id)), (0)::numeric))) - COALESCE(( SELECT sum(invoice_allocations.amount) AS sum
           FROM invoice_allocations
          WHERE (invoice_allocations.target_id = i.id)), (0)::numeric)) AS residual_amount
   FROM invoices i
  WHERE ((type)::text = 'invoice'::text);</createView>
