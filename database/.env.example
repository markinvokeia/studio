# ── Liquibase / PostgreSQL Connection ─────────────────────────────────────────
# Full JDBC URL format: jdbc:postgresql://HOST:PORT/DBNAME
#
# EasyPanel internal (within EasyPanel network):
#   jdbc:postgresql://postgres:5432/studio
# EasyPanel external (from developer laptop, requires port forwarding):
#   jdbc:postgresql://your-easypanel-host:PORT/studio
# Local development:
#   jdbc:postgresql://localhost:5432/studio
DB_URL=jdbc:postgresql://localhost:5432/studio

DB_USER=postgres
DB_PASS=changeme

# Target schema for application tables (leave "public" unless multi-tenant)
DB_SCHEMA=public

# Schema where Liquibase tracking tables live (DATABASECHANGELOG, DATABASECHANGELOGLOCK)
DB_CHANGELOG_SCHEMA=public

# ── Environment Tag ────────────────────────────────────────────────────────────
# Controls safety prompts and seed data context.
# Values: local | dev | staging | CLIENTE | PROD
#
# PROD and CLIENTE: require typing "CONFIRMO" before any deploy or rollback.
# local and dev:    seed data scripts ARE executed.
# staging, CLIENTE, PROD: seed data scripts are NEVER executed.
ENVIRONMENT=local

# ── Docker Image ───────────────────────────────────────────────────────────────
# Pinned Liquibase Docker image. Do not change without testing.
LIQUIBASE_IMAGE=liquibase/liquibase:5.0
