    {
      "id": "code-adjustments-upsert-parse",
      "name": "Parse Adjustment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [320, 1000],
      "parameters": {
        "jsCode": "const b = $input.first().json.body || $input.first().json;\nreturn [{ json: {\n  id:              b.id || '',\n  payroll_entry_id: b.payroll_entry_id || '',\n  description:     b.description || '',\n  amount:          b.amount != null ? String(Math.abs(b.amount)) : '0',\n  adjustment_type: b.adjustment_type || 'addition',\n  category:        b.category || 'otro',\n  created_by:      b.created_by || ''\n} }];"
      }
    },
    {
      "id": "pg-adjustments-upsert",
      "name": "Upsert Adjustment",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [540, 1000],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO payroll_manual_adjustments (id, payroll_entry_id, description, amount, adjustment_type, category, created_by)\nVALUES (COALESCE(NULLIF($1,'')::uuid, gen_random_uuid()), $2::uuid, $3, $4::decimal, $5::adjustment_type_enum, $6::adjustment_category_enum, NULLIF($7,'')::uuid)\nON CONFLICT (id) DO UPDATE SET\n  description     = EXCLUDED.description,\n  amount          = EXCLUDED.amount,\n  adjustment_type = EXCLUDED.adjustment_type,\n  category        = EXCLUDED.category\nRETURNING id, amount, adjustment_type",
        "additionalFields": {
          "queryParams": "={{ [$json.id,$json.payroll_entry_id,$json.description,$json.amount,$json.adjustment_type,$json.category,$json.created_by] }}"
        }
      },
      "credentials": { "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Postgres" } }
    },
    {
      "id": "pg-adjustments-recalc",
      "name": "Recalculate Entry After Adjustment",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [760, 1000],
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH adj_total AS (\n  SELECT\n    payroll_entry_id,\n    SUM(CASE WHEN adjustment_type='addition' THEN amount ELSE -amount END) AS adj_sum\n  FROM payroll_manual_adjustments\n  WHERE payroll_entry_id = (SELECT payroll_entry_id FROM payroll_manual_adjustments WHERE id = $1::uuid)\n  GROUP BY payroll_entry_id\n)\nUPDATE payroll_entries pe SET\n  other_deductions = GREATEST(0, -COALESCE(a.adj_sum,0)),\n  net_salary = pe.gross_salary - pe.total_deductions + COALESCE(a.adj_sum, 0)\nFROM adj_total a\nWHERE pe.id = a.payroll_entry_id\nRETURNING pe.id, pe.net_salary",
        "additionalFields": {
          "queryParams": "={{ [$json.id] }}"
        }
      },
      "credentials": { "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Postgres" } }
    },
