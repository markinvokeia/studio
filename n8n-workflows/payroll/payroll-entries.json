    {
      "id": "pg-entries-detail",
      "name": "Entry Detail",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [320, 280],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT pe.*, u.name AS doctor_name, dc.contract_type, dc.calculation_type, dc.percentage_rate,\n  pp.period_year, pp.period_month,\n  (\n    SELECT json_agg(pma ORDER BY pma.created_at)\n    FROM payroll_manual_adjustments pma WHERE pma.payroll_entry_id = pe.id\n  ) AS adjustments,\n  (\n    SELECT json_agg(psa ORDER BY psa.session_date DESC)\n    FROM payroll_session_assignments psa WHERE psa.payroll_entry_id = pe.id\n    LIMIT 200\n  ) AS sessions\nFROM payroll_entries pe\nLEFT JOIN users u ON pe.doctor_id = u.id\nLEFT JOIN doctor_contracts dc ON pe.doctor_contract_id = dc.id\nLEFT JOIN payroll_periods pp ON pe.payroll_period_id = pp.id\nWHERE pe.id = $1::uuid",
        "additionalFields": {
          "queryParams": "={{ [$input.first().json.query?.id] }}"
        }
      },
      "credentials": { "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Postgres" } }
