      "name": "Update Entry",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [320, 460],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE payroll_entries SET\n  notes  = COALESCE(NULLIF($2,''), notes),\n  status = COALESCE(NULLIF($3,'')::payroll_entry_status_enum, status)\nWHERE id = $1::uuid\nRETURNING id, status, notes",
        "additionalFields": {
          "queryParams": "={{ [b=($input.first().json.body||$input.first().json), b.id, b.notes||'', b.status||''] }.slice(1) }}"
        }
      },
      "credentials": { "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Postgres" } }
    },
    {
      "id": "code-entries-update-parse",
