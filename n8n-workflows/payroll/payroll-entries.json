    {
      "id": "pg-entries-by-period",
      "name": "Entries By Period",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [320, 100],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT pe.*, u.name AS doctor_name, dc.contract_type, dc.calculation_type,\n  COALESCE((\n    SELECT SUM(CASE WHEN adjustment_type='addition' THEN amount ELSE -amount END)\n    FROM payroll_manual_adjustments pma WHERE pma.payroll_entry_id = pe.id\n  ), 0) AS manual_adjustments_total\nFROM payroll_entries pe\nLEFT JOIN users u ON pe.doctor_id = u.id\nLEFT JOIN doctor_contracts dc ON pe.doctor_contract_id = dc.id\nWHERE pe.payroll_period_id = $1::uuid\n  AND ($2::uuid IS NULL OR pe.doctor_id = $2::uuid)\nORDER BY u.name",
        "additionalFields": {
          "queryParams": "={{ [$input.first().json.query?.period_id, ($input.first().json.query?.doctor_id || null)] }}"
        }
      },
      "credentials": { "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Postgres" } }
    },
