      "id": "wh-entries-by-period",
      "name": "GET /payroll/entries/by-period",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [100, 100],
      "parameters": {
        "httpMethod": "GET",
        "path": "payroll/entries/by-period",
