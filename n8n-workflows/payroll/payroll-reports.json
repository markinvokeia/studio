      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { data: $input.first().json, report_type: 'accounting_entries' } }}",
        "options": { "responseCode": 200 }
      }
    },
    {
      "id": "wh-report-receipts",
      "name": "GET /payroll/reports/receipts-batch",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [100, 1000],
      "parameters": {
