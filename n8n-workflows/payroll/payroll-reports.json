    {
      "id": "pg-report-receipts",
      "name": "Receipts Batch Data",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [320, 1000],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  pe.id AS entry_id,\n  u.name, u.identity_document,\n  pp.period_year, pp.period_month,\n  pe.gross_salary, pe.bps_employee, pe.fonasa_employee,\n  pe.irpf_withholding, pe.other_deductions, pe.total_deductions,\n  pe.net_salary, pe.sessions_count, pe.hours_worked,\n  pe.bps_employer, pe.fonasa_employer,\n  pe.aguinaldo_provision, pe.vacation_provision,\n  pe.currency, pe.status\nFROM payroll_entries pe\nJOIN payroll_periods pp ON pe.payroll_period_id = pp.id\nJOIN users u ON pe.doctor_id = u.id\nWHERE pp.id = $1::uuid\nORDER BY u.name",
        "additionalFields": {
          "queryParams": "={{ [$input.first().json.query?.period_id] }}"
        }
      },
      "credentials": { "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Postgres" } }
    },
    {
