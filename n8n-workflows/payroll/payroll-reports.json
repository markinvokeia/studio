      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { data: $input.all().map(i => i.json), report_type: 'bank_file' } }}",
        "options": { "responseCode": 200 }
      }
    },
    {
      "id": "wh-report-accounting",
      "name": "GET /payroll/reports/accounting-entries",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [100, 820],
      "parameters": {
        "httpMethod": "GET",
        "path": "payroll/reports/accounting-entries",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "pg-report-accounting",
      "name": "Accounting Entries Data",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [320, 820],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  pp.period_year, pp.period_month,\n  SUM(pe.gross_salary)          AS total_salarios_brutos,\n  SUM(pe.bps_employee)          AS total_bps_obrero,\n  SUM(pe.fonasa_employee)       AS total_fonasa_obrero,\n  SUM(pe.irpf_withholding)      AS total_irpf,\n  SUM(pe.net_salary)            AS total_salarios_netos,\n  SUM(pe.bps_employer)          AS total_bps_patronal,\n  SUM(pe.fonasa_employer)       AS total_fonasa_patronal,\n  SUM(pe.aguinaldo_provision)   AS total_provision_aguinaldo,\n  SUM(pe.vacation_provision)    AS total_provision_vacacional,\n  SUM(pe.total_employer_cost)   AS costo_total_empresa\nFROM payroll_entries pe\nJOIN payroll_periods pp ON pe.payroll_period_id = pp.id\nWHERE pp.id = $1::uuid\nGROUP BY pp.period_year, pp.period_month",
        "additionalFields": {
          "queryParams": "={{ [$input.first().json.query?.period_id] }}"
        }
      },
      "credentials": { "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Postgres" } }
    },
    {
      "id": "resp-report-accounting",
