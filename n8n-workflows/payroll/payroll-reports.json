    {
      "id": "wh-report-cost-center",
      "name": "GET /payroll/reports/cost-by-center",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [100, 1180],
      "parameters": {
        "httpMethod": "GET",
        "path": "payroll/reports/cost-by-center",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "pg-report-cost-center",
      "name": "Cost Center Data",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [320, 1180],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  c.name  AS clinic_name,\n  pp.period_year, pp.period_month,\n  COUNT(pe.id)::integer         AS headcount,\n  SUM(pe.gross_salary)          AS total_bruto,\n  SUM(pe.total_employer_cost)   AS costo_total\nFROM payroll_entries pe\nJOIN payroll_periods pp ON pe.payroll_period_id = pp.id\nJOIN clinic c ON pp.clinic_id = c.id\nWHERE pp.period_year = $1::integer\n  AND ($2::integer IS NULL OR pp.period_month = $2::integer)\nGROUP BY c.name, pp.period_year, pp.period_month\nORDER BY pp.period_month, c.name",
        "additionalFields": {
          "queryParams": "={{ [($input.first().json.query?.year||new Date().getFullYear()), ($input.first().json.query?.month ? Number($input.first().json.query.month) : null)] }}"
        }
      },
      "credentials": { "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Postgres" } }
    },
    {
      "id": "resp-report-cost-center",
      "name": "Respond Cost Center",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [540, 1180],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { data: $input.all().map(i => i.json), report_type: 'cost_by_center' } }}",
        "options": { "responseCode": 200 }
      }
    }
