    {
      "id": "code-categories-upsert-parse",
      "name": "Parse Category",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [320, 620],
      "parameters": {
        "jsCode": "const b = $input.first().json.body || $input.first().json;\nreturn [{ json: {\n  id:                 b.id || '',\n  codigo:             b.codigo || '',\n  nombre:             b.nombre || '',\n  subgrupo:           b.subgrupo || '',\n  descripcion:        b.descripcion || '',\n  salario_minimo_uyu: b.salario_minimo_uyu ?? 0,\n  vigente_desde:      b.vigente_desde || '',\n  vigente_hasta:      b.vigente_hasta || ''\n} }];"
      }
    },
    {
      "id": "pg-categories-upsert",
      "name": "Upsert Category",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [540, 620],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO payroll_categories (id, codigo, nombre, subgrupo, descripcion, salario_minimo_uyu, vigente_desde, vigente_hasta)\nVALUES (COALESCE(NULLIF($1,'')::uuid, gen_random_uuid()), $2, $3, NULLIF($4,''), NULLIF($5,''), $6::decimal, $7::date, NULLIF($8,'')::date)\nON CONFLICT (id) DO UPDATE SET\n  codigo             = EXCLUDED.codigo,\n  nombre             = EXCLUDED.nombre,\n  subgrupo           = EXCLUDED.subgrupo,\n  descripcion        = EXCLUDED.descripcion,\n  salario_minimo_uyu = EXCLUDED.salario_minimo_uyu,\n  vigente_desde      = EXCLUDED.vigente_desde,\n  vigente_hasta      = EXCLUDED.vigente_hasta\nRETURNING id, codigo, nombre",
        "additionalFields": {
          "queryParams": "={{ [$json.id, $json.codigo, $json.nombre, $json.subgrupo, $json.descripcion, $json.salario_minimo_uyu, $json.vigente_desde, $json.vigente_hasta] }}"
        }
