    {
      "id": "wh-settings-get",
      "name": "GET /payroll/settings",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [100, 100],
      "parameters": {
        "httpMethod": "GET",
        "path": "payroll/settings",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "pg-settings-get",
      "name": "Fetch Settings",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [320, 100],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT setting_key, setting_value, description, updated_at FROM payroll_settings ORDER BY setting_key",
        "additionalFields": {}
      },
      "credentials": { "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Postgres" } }
    },
    {
      "id": "code-settings-get-resp",
      "name": "Build Settings Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [540, 100],
      "parameters": {
        "jsCode": "const rows = $input.all();\nconst settings = {};\nfor (const r of rows) {\n  settings[r.json.setting_key] = r.json.setting_value;\n}\nreturn [{ json: { data: settings, rows: rows.map(r => r.json) } }];"
      }
    },
    {
      "id": "resp-settings-get",
      "name": "Respond Settings",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [760, 100],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}",
        "options": { "responseCode": 200 }
      }
    },
    {
      "id": "wh-settings-update",
      "name": "POST /payroll/settings/update",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [100, 280],
      "parameters": {
        "httpMethod": "POST",
        "path": "payroll/settings/update",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "code-settings-update-parse",
      "name": "Parse Settings Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [320, 280],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst { settings, updated_by } = body;\nif (!settings || !Array.isArray(settings) || settings.length === 0) {\n  throw new Error('settings must be a non-empty array of {key, value} objects');\n}\nconst keys = settings.map(s => s.key);\nconst values = settings.map(s => JSON.stringify(s.value));\nreturn [{ json: { keys, values, updated_by: updated_by || '' } }];"
      }
    },
    {
      "id": "pg-settings-update",
      "name": "Update Settings Bulk",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [540, 280],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE payroll_settings ps\nSET\n  setting_value = upd.val::jsonb,\n  updated_at    = NOW(),\n  updated_by    = NULLIF($3, '')::uuid\nFROM (\n  SELECT unnest($1::text[]) AS k, unnest($2::text[]) AS val\n) upd\nWHERE ps.setting_key = upd.k\nRETURNING ps.setting_key, ps.setting_value",
        "additionalFields": {
          "queryParams": "={{ [$json.keys, $json.values, $json.updated_by] }}"
        }
      },
      "credentials": { "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Postgres" } }
    },
    {
      "id": "resp-settings-update",
      "name": "Respond Settings Update",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [760, 280],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { data: $input.all().map(i => i.json), success: true } }}",
        "options": { "responseCode": 200 }
      }
    },
