      "parameters": {
        "jsCode": "const b = $input.first().json.body || $input.first().json;\nif (!b.user_id || !b.category_id || !b.fecha_ingreso) throw new Error('Faltan campos requeridos: user_id, category_id, fecha_ingreso');\nreturn [{ json: {\n  user_id: b.user_id,\n  category_id: b.category_id,\n  fecha_ingreso: b.fecha_ingreso,\n  clinic_id: b.clinic_id ? String(b.clinic_id) : ''\n} }];"
      }
