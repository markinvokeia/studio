    {
      "id": "code-employees-link-prepare",
      "name": "Prepare Employee Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [760, 740],
      "parameters": {
        "jsCode": "const link = $('Parse Link User').first().json;\nconst user = $input.first().json;\nif (!user || !user.id) throw new Error('Usuario no encontrado');\n\n// Split name: first word = nombres, rest = apellidos\nconst nameParts = (user.name || '').trim().split(/\\s+/);\nconst nombres = nameParts.length > 1 ? nameParts.slice(0, -1).join(' ') : user.name || '';\nconst apellidos = nameParts.length > 1 ? nameParts[nameParts.length - 1] : '';\n\nreturn [{ json: {\n  user_id: user.id,\n  clinic_id: link.clinic_id || '',\n  category_id: link.category_id,\n  fecha_ingreso: link.fecha_ingreso,\n  nombres,\n  apellidos,\n  email: user.email || '',\n  telefono: user.phone_number || '',\n  cedula: user.identity_document || '',\n  fecha_nacimiento: user.birth_date || '',\n  domicilio: user.address || '',\n  cuenta_banco: user.bank_account || '',\n  foto_url: user.avatar || ''\n} }];"
      }
    },
