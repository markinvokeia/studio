        "query": "INSERT INTO payroll_employees\n  (id, clinic_id, cedula, nombres, apellidos, fecha_nacimiento, sexo, estado_civil,\n   domicilio, telefono, email, banco, cuenta_banco, numero_bps, fecha_ingreso, foto_url, activo)\nVALUES\n  (COALESCE(NULLIF($1,'')::uuid, gen_random_uuid()),\n   $2::integer,\n   $3, $4, $5,\n   NULLIF($6,'')::date,\n   NULLIF($7,'')::sexo_enum,\n   NULLIF($8,'')::estado_civil_enum,\n   NULLIF($9,''), NULLIF($10,''), NULLIF($11,''),\n   NULLIF($12,''), NULLIF($13,''), NULLIF($14,''),\n   $15::date,\n   NULLIF($16,''),\n   $17::boolean)\nON CONFLICT (id) DO UPDATE SET\n  cedula          = EXCLUDED.cedula,\n  nombres         = EXCLUDED.nombres,\n  apellidos       = EXCLUDED.apellidos,\n  fecha_nacimiento = EXCLUDED.fecha_nacimiento,\n  sexo            = EXCLUDED.sexo,\n  estado_civil    = EXCLUDED.estado_civil,\n  domicilio       = EXCLUDED.domicilio,\n  telefono        = EXCLUDED.telefono,\n  email           = EXCLUDED.email,\n  banco           = EXCLUDED.banco,\n  cuenta_banco    = EXCLUDED.cuenta_banco,\n  numero_bps      = EXCLUDED.numero_bps,\n  fecha_ingreso   = EXCLUDED.fecha_ingreso,\n  foto_url        = EXCLUDED.foto_url,\n  activo          = EXCLUDED.activo,\n  updated_at      = NOW()\nRETURNING id",
        "additionalFields": {
