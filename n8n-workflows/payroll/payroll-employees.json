      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT pe.*, pc.nombre AS category_name\nFROM payroll_employees pe\nLEFT JOIN payroll_employments pem ON pem.employee_id = pe.id AND pem.is_active = true\nLEFT JOIN payroll_categories pc ON pem.category_id = pc.id\nWHERE ($1::integer IS NULL OR pe.clinic_id = $1::integer)\n  AND ($2::boolean IS NULL OR pe.activo = $2::boolean)\nORDER BY pe.apellidos, pe.nombres",
        "additionalFields": {
          "queryParams": "={{ [($input.first().json.query?.clinic_id ? Number($input.first().json.query.clinic_id) : null), ($input.first().json.query?.activo != null ? $input.first().json.query.activo === 'true' : null)] }}"
