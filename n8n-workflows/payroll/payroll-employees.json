      "parameters": {
        "jsCode": "const b = $input.first().json.body || $input.first().json;\nreturn [{ json: {\n  id: b.id || '',\n  clinic_id: b.clinic_id ? String(b.clinic_id) : '',\n  cedula: b.cedula || '',\n  nombres: b.nombres || '',\n  apellidos: b.apellidos || '',\n  fecha_nacimiento: b.fecha_nacimiento || '',\n  sexo: b.sexo || '',\n  estado_civil: b.estado_civil || '',\n  domicilio: b.domicilio || '',\n  telefono: b.telefono || '',\n  email: b.email || '',\n  banco: b.banco || '',\n  cuenta_banco: b.cuenta_banco || '',\n  numero_bps: b.numero_bps || '',\n  fecha_ingreso: b.fecha_ingreso || '',\n  foto_url: b.foto_url || '',\n  activo: b.activo !== false\n} }];"
