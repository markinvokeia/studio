    {
      "id": "pg-honorarios-list",
      "name": "List Honorarios",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [320, 100],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT ph.*, u.name AS doctor_name, dc.contract_type, dc.calculation_type,\n  pp.period_year, pp.period_month\nFROM payroll_honorarios ph\nLEFT JOIN doctor_contracts dc ON ph.contract_id = dc.id\nLEFT JOIN users u ON dc.doctor_id = u.id\nLEFT JOIN payroll_periods pp ON ph.period_id = pp.id\nWHERE ($1::uuid IS NULL OR ph.period_id = $1::uuid)\n  AND ($2::uuid IS NULL OR dc.doctor_id = $2::uuid)\n  AND ($3::text IS NULL OR ph.status::text = $3)\nORDER BY ph.period_start_date DESC, u.name",
        "additionalFields": {
          "queryParams": "={{ [($input.first().json.query?.period_id||null),($input.first().json.query?.doctor_id||null),($input.first().json.query?.status||null)] }}"
        }
      },
      "credentials": { "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Postgres" } }
    },
    {
      "id": "resp-honorarios-list",
      "name": "Respond Honorarios List",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [540, 100],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { data: $input.all().map(i => i.json) } }}",
        "options": { "responseCode": 200 }
      }
    },
    {
