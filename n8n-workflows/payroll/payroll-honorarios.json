    {
      "id": "pg-honorarios-validate",
      "name": "Validate Invoice",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [540, 460],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE payroll_honorarios\nSET status = 'invoice_validated', invoice_number = NULLIF($2,''), invoice_amount = NULLIF($3,'')::decimal, updated_at = NOW()\nWHERE id = $1::uuid\nRETURNING id, status, invoice_number, invoice_amount",
        "additionalFields": {
          "queryParams": "={{ [$json.id,$json.invoice_number,$json.invoice_amount] }}"
        }
      },
      "credentials": { "postgres": { "id": "POSTGRES_CREDENTIAL_ID", "name": "Postgres" } }
