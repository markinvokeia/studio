      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE payroll_honorarios\nSET status = 'pending_invoice', updated_at = NOW()\nWHERE id = $1::uuid AND status = 'draft'\nRETURNING id, status, gross_amount",
        "additionalFields": {
          "queryParams": "={{ [($input.first().json.body||$input.first().json).id] }}"
        }
      },
