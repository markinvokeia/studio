      "name": "Parse Validate Invoice",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [320, 460],
      "parameters": {
        "jsCode": "const b = $input.first().json.body || $input.first().json;\nreturn [{ json: {\n  id:             b.id || '',\n  invoice_number: b.invoice_number || '',\n  invoice_amount: b.invoice_amount != null ? String(b.invoice_amount) : ''\n} }];"
      }
